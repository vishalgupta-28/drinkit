# ─────────────────────────────────────────────────────────────
# DrinkIt — Environment Variables
# Copy this file to `.env` and fill in real values.
# ─────────────────────────────────────────────────────────────

# ── Core Infrastructure ──────────────────────────────────────
POSTGRES_USER=drinkit
POSTGRES_PASSWORD=drinkit_secret
POSTGRES_DB=drinkit
# Hostname `postgres` = docker-compose service name
DATABASE_URL=postgresql://drinkit:drinkit_secret@postgres:5432/drinkit
# asyncpg variant for FastAPI services
DATABASE_URL_ASYNC=postgresql+asyncpg://drinkit:drinkit_secret@postgres:5432/drinkit

REDIS_URL=redis://redis:6379/0

RABBITMQ_DEFAULT_USER=drinkit
RABBITMQ_DEFAULT_PASS=drinkit_secret
RABBITMQ_URL=amqp://drinkit:drinkit_secret@rabbitmq:5672/

# ── Auth / JWT ───────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_EXPIRY=3600          # seconds (access token)
JWT_REFRESH_EXPIRY=604800 # seconds (refresh token, 7 days)

# ── Third-party APIs ─────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_server_key

# OTP over SMS
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+10000000000

# Payments
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ── Frontend (Next.js — must be prefixed NEXT_PUBLIC_) ────────
NEXT_PUBLIC_API_URL=http://localhost:8080/api
NEXT_PUBLIC_WS_URL=http://localhost:8080
NEXT_PUBLIC_GOOGLE_MAPS_KEY=your_google_maps_browser_key
